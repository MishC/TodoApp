@page "/todos"
@inject IJSRuntime JSRuntime


@if (visible)
{          <h2 class="mt-5 mb-2 text-center pt-5"> Todos @EmojiString</h2>

    <div class="d-flex justify-content-start mb-4">  

        <div class="input-group w-75 mx-auto mt-5 pt-2">

            <input type="text" @bind="newTodo" class="form-control" aria-label="Todo"
                   aria-describedby="button-addon1" placeholder="Enter a new todo..." @onkeydown="HandleEnter" />
            <button class="btn btn-success px-4" type="button" id="button-addon1"
                    @onclick="AddTodo">Add</button>
        </div>
    </div>
    <!-- List of todos -->
    @if (todos?.Count > 0)
    {
        <ul class="list-group mt-5 pt-2 mx-1 w-75 mx-auto">
              <li class="list-group-item list-group-item-primary d-flex justify-content-between align-items-center px-4 text-white"
                  style="background-color:#0056b3">
            <span class="justify-content-start">Created at</span>
            <div>Title</div>
              <div ></div></li>
            @foreach (var todo in todos)
            { 
       if (!todo.Completed) 
            {
           <li class="list-group-item d-flex justify-content-between align-items-center px-4" @key="todo.Id">
               <div class="justify-content-start"> 
                   <span class="mr-3" style="color: #814141"> 
                    @todo.CurrentDate.ToString("HH:mm")  &nbsp;&nbsp; </span> 
                   <span class="" style="color: #5C4033"> 
 @todo.CurrentDate.ToString("dd/MM/yyyy")   </span> 
               </div>
                    <span class="mx-5 px-5">@todo.Title</span>
      
      
           
               <div class="d-flex justify-content-end align-items-center">
         
                  <div class="form-check mx-1 cursor-pointer">
                     <input class="form-check-input" type="checkbox" value="" id="defaultCheck1" @onchange="async()=>await ToggleAsync(todo)" unchecked/>
                  </div>
             <!--   <button type="button" class="btn btn-sm" @onclick="async () => await ConfirmDelete(todo)"></button>--> 

                   <button type="button" class="btn btn-sm" @onclick="() => ShowDeleteModalAsync(todo)">@emoji[2]</button>

                </div>
         </li>


            }
            }
        </ul>
    }
   
}

else
{
    <CascadingValue Value="completedTasks">
        <DoneComponent completedTasks="completedTasks" OnTakeBack="HandleTakeBack" />
    </CascadingValue>
}


@* Bootstrap Modal alert*@
<div class="modal fade" id="alertModal" tabindex="-1" aria-labelledby="alertModalLabel" aria-hidden="true">
    <div class="modal-dialog ">
        <div class="modal-content"> 
            <div class="modal-header alert-primary">
                <h5 class="modal-title" id="alertModalLabel">Completed!</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body alert-primary" role="alert">
                @AlertMessage
            </div>
            <div class="modal-footer alert-primary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@* Bootstrao Modal confirmDelete*@
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog alert-danger">
        <div class="modal-content alert-danger">
            <div class="modal-header alert-danger border-0">
                <h5 class="modal-title" id="confirmDeleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body alert-danger border-0">
                Are you sure you want to delete this todo?
            </div>
            <div class="modal-footer alert-danger border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>



@code {
    [Parameter] public bool visible { get; set; }  

    private string newTodo = string.Empty;
    private List<TodoItem> todos = new();
    private List<TodoItem> completedTasks = new();
    private List<char> emoji = new(){ (char)0x2610, (char)0x2705,(char)0x274C };
    private string AlertMessage { get; set; }= string.Empty;

    private byte[] emojiBytes { get; set; } = Array.Empty<byte>();
    private string EmojiString => System.Text.Encoding.Unicode.GetString(emojiBytes);

    protected override void OnInitialized()
    {
        base.OnInitialized();
        UpdateCompletedTasks(); 
         EmojiService.HighSurrogate=0xD83D;
        EmojiService.LowSurrogate=0xDD59;
       emojiBytes= EmojiService.GetEmojiBytes();
      
    }

    private void AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(newTodo))
        {
            var todo = new TodoItem { Title = newTodo };
            todos.Add(todo);
            newTodo = string.Empty;
            UpdateCompletedTasks(); 
        }
    }

    private void HandleEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTodo();
        }
    }
    
    public List<TodoItem> GetCompletedTodos()
    {
        return todos.Where(t => t.Completed).ToList();
    }
    
    private void UpdateCompletedTasks()
    {
        completedTasks = GetCompletedTodos();
    }
    
    
    private async Task UpdateCompletedTasksAsync()
    {
    await Task.Delay(500); 
    completedTasks = GetCompletedTodos();
    }

    private async Task ToggleAsync(TodoItem todo)
    { 
      await Task.Delay(500); 
     ShowCompletionAlert(todo.Title);
     await Task.Delay(500); 
    todo.Completed = !todo.Completed;

    await UpdateCompletedTasksAsync();
    }

    private void ToggleComplete(TodoItem todo)

    { 
        todo.Completed = !todo.Completed;
        
        if (todo.Completed)
        {
            ShowCompletionAlert(todo.Title);
        }

        UpdateCompletedTasks(); 
    }

   

    private void DeleteTodo(TodoItem todo)
    {
        todos?.Remove(todo);
        UpdateCompletedTasks(); 
    }

    private void HandleTakeBack(TodoItem todo)
    {
        ToggleComplete(todo);
    }

  

  <!--  private async Task ConfirmDelete(TodoItem todo)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "You are going to DELETE your todo. Are you sure?");
        if (confirmed)
        {
            DeleteTodo(todo);
        }
    }-->

    private async void ShowCompletionAlert(string title)
    {    <!--AlertMessage=title;
        await JSRuntime.InvokeVoidAsync("alert", $"The task '{title}' has been marked as completed.");-->
     AlertMessage="";
    AlertMessage =$"The task '{title}' has been marked as completed.";
        StateHasChanged(); 

        await JSRuntime.InvokeVoidAsync("bootstrapInterop.showAlertModal");

    }

    private TodoItem? todoToDelete;

    public async Task ShowDeleteModalAsync(TodoItem todo)
    {
        todoToDelete = todo;
        await JSRuntime.InvokeVoidAsync("bootstrapInterop.showModal", "confirmDeleteModal");
    }

    public async Task ConfirmDelete()
    {
        await JSRuntime.InvokeVoidAsync("bootstrapInterop.hideModal", "confirmDeleteModal");
        if (todoToDelete != null)
        {
            DeleteTodo(todoToDelete);
        }
    }

    }